{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NeverLost Workbench",
  "version": "1.0.0",
  "identifier": "com.neverlost.workbench",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NeverLost Workbench",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "visible": true
      }
    ],
    "security": {
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": [
      "icons/icon.ico"
    ],
    "windows": {
      "digestAlgorithm": "sha256"
    }
  }
}
